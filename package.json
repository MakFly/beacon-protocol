{
  "name": "@makfly/beacon-protocol",
  "version": "0.1.0",
  "description": "Beacon wire-protocol — shared TypeScript types + constants for errors/traces/logs telemetry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakFly/beacon-protocol.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && tsc --emitDeclarationOnly --declaration --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": { "node": ">=18" }
}
